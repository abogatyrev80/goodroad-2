{
  "$schema": "https://opencode.ai/config.json",
  "model": "ollama/qwen2.5-coder:14b",
  "small_model": "ollama/qwen2.5-coder:14b",
  "agent": {
    "coder": {
      "description": "Local coding agent using Qwen2.5-Coder 14B on AMD GPU",
      "model": "ollama/qwen2.5-coder:14b",
      "mode": "primary",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow"
      }
    }
  },
  "default_agent": "coder"
}
