# ========================================
# Good Road Backend — Environment Variables
# ========================================

# --- MongoDB ---
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=good_road_db

# --- Neural Network Model ---
# Path to trained model (.pt for PyTorch, .keras for TensorFlow)
NEURAL_MODEL_PATH=models/accel_lstm.pt

# --- NN Backend Selection ---
# Options: auto | pytorch | onnx | remote
# auto: tries PyTorch -> ONNX -> Remote in order
NN_INFERENCE_BACKEND=auto

# Device selection: auto | cpu | cuda | gpu | rocm
# auto: auto-detects GPU (CUDA/ROCm) or falls back to CPU
NN_DEVICE=auto

# Use nn_backend abstraction (true/false)
# When true, uses nn_backend.py for inference with fallback support
NN_USE_NN_BACKEND=false

# Auto-convert .pt model to ONNX on first load (true/false)
NN_AUTO_CONVERT_ONNX=true

# Remote GPU server URL (for nn_backend=remote)
NN_REMOTE_GPU_URL=

# Remote GPU request timeout in seconds
NN_REMOTE_GPU_TIMEOUT=5.0

# --- Inference Worker ---
# How often to process raw sensor data (seconds)
NN_INFERENCE_INTERVAL=30

# Batch size for inference processing
NN_INFERENCE_BATCH_SIZE=50

# Minimum neural network confidence to use prediction (0.0-1.0)
NEURAL_MIN_CONFIDENCE=0.35

# --- Auto-Retraining ---
# Number of new events needed to trigger retrain
NN_RETRAIN_THRESHOLD=1000

# Minimum samples per class for retrain
NN_MIN_SAMPLES_PER_CLASS=100

# How often to check for retrain (seconds)
NN_RETRAIN_CHECK_INTERVAL=300

# Enable model versioning (true/false)
NN_MODEL_VERSIONING=true

# --- External Training Server ---
# Enable training on external GPU server (true/false)
EXTERNAL_TRAINING_ENABLED=false

# External GPU server URL for training
EXTERNAL_TRAINING_GPU_SERVER_URL=

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW=60

# --- Server ---
# HOST=0.0.0.0
# PORT=8000

# ========================================
# Deployment Scenarios
# ========================================

# --- Local Development (GPU available) ---
# NN_DEVICE=auto
# NN_INFERENCE_BACKEND=pytorch
# NN_USE_NN_BACKEND=false

# --- Cloud Server (CPU only) ---
# NN_DEVICE=cpu
# NN_INFERENCE_BACKEND=pytorch
# NN_USE_NN_BACKEND=false

# --- Cloud Server with ONNX (faster CPU) ---
# NN_DEVICE=cpu
# NN_INFERENCE_BACKEND=onnx
# NN_USE_NN_BACKEND=true

# --- Cloud + Remote GPU Training ---
# NN_DEVICE=cpu
# NN_INFERENCE_BACKEND=auto
# EXTERNAL_TRAINING_ENABLED=true
# EXTERNAL_TRAINING_GPU_SERVER_URL=https://your-gpu-server:8000

# --- Cloud + Remote GPU Inference ---
# NN_DEVICE=cpu
# NN_INFERENCE_BACKEND=remote
# NN_REMOTE_GPU_URL=https://your-gpu-server:8000
